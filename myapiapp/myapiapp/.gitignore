## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleasePublic/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# Rider
.idea/
*.sln.iml

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# NuGet Packages
*.nupkg
*.snupkg
# NuGet will skip any files named .nupkg.
# NuGet does use .nuspec files, but they are usually not checked into source control.
# Uncomment this if necessary however:
#!*.nuspec

# NuGet v3's project.json files produces more ignorable files than V2's packages.config
# files, and the hidden folder .nuget is used as well:
.nuget/

# Typical ASP.NET Core build output directories
project.lock.json
project.fragment.lock.json
artifacts/

# The packages folder can be ignored because of Package Restore
**/packages/*
# except build/, which is used as an MSBuild target.
# Uncomment if necessary however:
#!**/packages/build/
# and loose file entries
*.VC.db
*.VC.VC.opendb
